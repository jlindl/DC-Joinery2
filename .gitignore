# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Claude Code harness state — do not commit
.claude/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.vscode/
.idea/
*.swp
*.pem

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Stale flatten artefact — delete after restart releases the .next file lock
my-app/

# typescript
*.tsbuildinfo
next-env.d.ts
